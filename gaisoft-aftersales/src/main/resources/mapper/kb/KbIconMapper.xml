<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.gaisoft.kb.mapper.KbIconMapper">
    
    <resultMap type="KbIcon" id="KbIconResult">
        <result property="id"    column="id"    />
        <result property="icon"    column="icon"    />
        <result property="name"    column="name"    />
    </resultMap>

    <sql id="selectKbIconVo">
        select id, icon, name from kb_icon
    </sql>

    <select id="selectKbIconList" parameterType="KbIcon" resultMap="KbIconResult">
        <include refid="selectKbIconVo"/>
        <where>  
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>
    
    <select id="selectKbIconById" parameterType="Long" resultMap="KbIconResult">
        <include refid="selectKbIconVo"/>
        where id = #{id}
    </select>

    <insert id="insertKbIcon" parameterType="KbIcon" useGeneratedKeys="true" keyProperty="id">
        insert into kb_icon
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="icon != null">icon,</if>
            <if test="name != null">name,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="icon != null">#{icon},</if>
            <if test="name != null">#{name},</if>
         </trim>
    </insert>

    <update id="updateKbIcon" parameterType="KbIcon">
        update kb_icon
        <trim prefix="SET" suffixOverrides=",">
            <if test="icon != null">icon = #{icon},</if>
            <if test="name != null">name = #{name},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteKbIconById" parameterType="Long">
        delete from kb_icon where id = #{id}
    </delete>

    <delete id="deleteKbIconByIds" parameterType="String">
        delete from kb_icon where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>